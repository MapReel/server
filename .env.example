APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:password@host:5432/postgres
SUPABASE_URL=
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/keys
GOOGLE_MAPS_API_KEY=
# Comma-separated allowlist (allow_credentials=True → no wildcard).
#   Web dev (Vite): http://localhost:5173
#   Capacitor iOS:  capacitor://localhost
#   Capacitor Android (androidScheme=https): https://localhost
#   Real-device dev: add the dev machine LAN IP origin (e.g. http://192.168.0.x:5173)
#   Web prod: add the deployed web origin (e.g. https://app.mapreel.com)
CORS_ORIGINS=http://localhost:5173,capacitor://localhost,https://localhost
